{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-froggy",
    "@warp-dot-dev/opencode-warp",
    "@pantheon-ai/opencode-warcraft-notifications"
  ],
  "share": "manual",
  "autoupdate": "notify",
  "formatter": true,
  "instructions": [
    "AGENTS.md"
  ],
  "permission": {
    "bash": {
      "*": "ask",
      "ls": "allow",
      "ls *": "allow",
      "pwd": "allow",
      "whoami": "allow",
      "echo *": "allow",
      "cat *": "allow",
      "which *": "allow",
      "where *": "allow",
      "git status": "allow",
      "git status *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git stat": "allow",
      "git stat *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git branch": "allow",
      "git branch *": "allow",
      "git remote": "allow",
      "git remote *": "allow"
    },
    "edit": "ask",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "question": "allow",
    "webfetch": "ask",
    "websearch": "allow"
  }
}
